# BuscaVenezuela / Guardian Sismico VE — Variables de entorno
# Copia este archivo como .env y rellena los valores reales

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Token del bot (obtenido de @BotFather)
BOT_TOKEN=your_telegram_bot_token

# ID del canal o grupo privado de rescatistas (negativo para grupos/canales)
# Ejemplo: -1001234567890
RESCUE_CHANNEL_ID=-100XXXXXXXXXX

# IDs de Telegram separados por coma que pueden usar /sos_pendientes
# Si esta vacio, cualquier usuario puede consultarlo (modo sin restriccion)
# Ejemplo: ADMIN_IDS=123456789,987654321
ADMIN_IDS=

# ── Base de datos ─────────────────────────────────────────────────────────────
# Ruta a la base de datos SQLite (puedes dejarlo por defecto)
DB_PATH=buscavenezuela.db

# ── Ambiente de ejecucion ─────────────────────────────────────────────────────
# 'development' → usa polling (local)
# 'production'  → usa webhook (VPS/Render/Railway)
ENVIRONMENT=development

# ── Webhook (solo para ENVIRONMENT=production) ────────────────────────────────
# URL publica de tu servidor con HTTPS
WEBHOOK_URL=https://tu-dominio.com
# Puerto donde escucha el webhook (Telegram solo acepta 443, 80, 88, 8443)
WEBHOOK_PORT=8443
